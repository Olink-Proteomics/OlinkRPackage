# Default used for local builds; CI overrides via build args
ARG R_VERSION=4.5.3
FROM ghcr.io/rocker-org/tidyverse:${R_VERSION}

# System libs
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
  apt-get update \
  && apt-get upgrade -y \
  && apt-get install -y libglpk40 \
    libxt6 \
    texlive-latex-base \
    texlive-fonts-recommended \
    texlive-fonts-extra \
    texlive-latex-extra \
  && rm -rf /var/lib/apt/lists/*

# R packages
RUN install2.r --error \
  --deps TRUE \
  --skipinstalled \
  devtools \
  rcmdcheck \
  lintr \
  lme4 \
  bspm \
  && rm -rf /tmp/downloaded_packages

# Create the .Rprofile file to update packages from a Posit Public PM snapshot.
# This is needed to update R libraries that are outdated in the original docker
# image. The docker image for:
# - R 4.1.3 has a snapshot from 2022-04-21 on Ubuntu 20.04 Focal.
# - R 4.2.3 has a snapshot from 2023-04-20 on Ubuntu 22.04 Jammy.
# - R 4.3.3 has a snapshot from 2024-04-23 on Ubuntu 22.04 Jammy.
# - R 4.4.3 has a snapshot from 2025-04-10 on Ubuntu 24.04 Noble.
# - R 4.5.3 has a snapshot from 2026-04-23 on Ubuntu 24.04 Noble.
# 
# Some of these snapshots do not host the latest version of certain packages
# (e.g. cli or dplyr). We will be using the following snapshots:
# - For R 4.1.3 snapshot from 2023-12-12.
# - For R 4.2.3 snapshot from 2023-12-12.
# - For R 4.3.3 snapshot from 2026-02-04. 
# - For R 4.4.3 snapshot from 2026-02-04. 
# - For R 4.5.3 snapshot from 2026-04-23 (unchanged).
# These are the snapshots when all packages satisfy the requiered versions for
# OlinkAnalyze.
#
# Each rocker image is built on a specific Ubuntu release, so the Posit Public
# Package Manager URL must match both the R version and the Ubuntu codename.
#
# These snapshots are chosen so that all packages satisfy the required versions
# for OlinkAnalyze.
#
ARG r_profile=.Rprofile

RUN set -e; \
  case "$R_VERSION" in \
    "4.1.3") ubuntu="focal"; snapshot="2023-12-12"; ubuntu_label="Ubuntu 20.04 Focal"; bioc="3.14" ;; \
    "4.2.3") ubuntu="jammy"; snapshot="2023-12-12"; ubuntu_label="Ubuntu 22.04 Jammy"; bioc="3.16" ;; \
    "4.3.3") ubuntu="jammy"; snapshot="2026-02-04"; ubuntu_label="Ubuntu 22.04 Jammy"; bioc="3.18" ;; \
    "4.4.3") ubuntu="noble"; snapshot="2026-02-04"; ubuntu_label="Ubuntu 24.04 Noble"; bioc="3.20" ;; \
    "4.5.3") ubuntu="noble"; snapshot="2026-04-23"; ubuntu_label="Ubuntu 24.04 Noble"; bioc="3.22" ;; \
    *) \
      echo "Unsupported R_VERSION: $R_VERSION. Please update docker/Dockerfile_for_tests snapshots accordingly." >&2; \
      exit 1 ;; \
  esac; \
  echo "Setting up snapshot for R $R_VERSION on $ubuntu_label from $snapshot"; \
  printf '%s\n' \
    "options(repos = c(" \
    "  CRAN = \"https://packagemanager.posit.co/cran/__linux__/$ubuntu/$snapshot\"" \
    "))" \
    > "$r_profile"

ENV _R_CHECK_FORCE_SUGGESTS_=FALSE

COPY OlinkAnalyze/DESCRIPTION /src/DESCRIPTION

# Force dplyr 1.2.0 only for legacy R 4.1.3 and 4.2.3.
# dplyr for R 4.3.3 and above is set correctly through PPM
RUN if [ "$R_VERSION" = "4.1.3" ] || [ "$R_VERSION" = "4.2.3" ]; then \
      R -q -e 'remotes::install_version("dplyr", version = "1.2.0", repos = "https://cloud.r-project.org")'; \
    fi

RUN R -e "devtools::install_dev_deps(pkg = '/src', dependencies = TRUE)"

ENTRYPOINT ["R", "--vanilla"]
